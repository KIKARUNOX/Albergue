{
  "functions": {
    "source": "firebase-functions"
  }
  , "hosting": {
    "public": "public",
    "headers": [
      {
        "source": "/**",
        "headers": [
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
          { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "no-referrer-when-downgrade" },
          { "key": "Content-Security-Policy", "value": "default-src 'self'" }
        ]
      }
    ],
    "redirects": [
      { "source": "/.env", "destination": "/404.html", "type": 403 },
      { "source": "/.git/**", "destination": "/404.html", "type": 403 },
      { "source": "/.git", "destination": "/404.html", "type": 403 },
      { "source": "/backup.zip", "destination": "/404.html", "type": 403 },
      { "source": "/backup.sql", "destination": "/404.html", "type": 403 },
      { "source": "/database.sql", "destination": "/404.html", "type": 403 },
      { "source": "/config.php", "destination": "/404.html", "type": 403 },
      { "source": "/wp-admin/**", "destination": "/404.html", "type": 403 },
      { "source": "/admin/**", "destination": "/404.html", "type": 403 },
      { "source": "/phpmyadmin/**", "destination": "/404.html", "type": 403 },
      { "source": "/phpinfo.php", "destination": "/404.html", "type": 403 },
      { "source": "/.htaccess", "destination": "/404.html", "type": 403 },
      { "source": "/.DS_Store", "destination": "/404.html", "type": 403 },
      { "source": "/server-status", "destination": "/404.html", "type": 403 }
    ]
  }
}
